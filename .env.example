# EPL Oracle v4.1 — Environment Variables

# Discord webhook for alerts (required for --alert picks/recap)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_url_here

# Email alerts via Resend API (optional — sends picks + recap to email alongside Discord)
RESEND_API_KEY=
EMAIL_TO=kalchi.picks@gmail.com

# The Odds API key (optional — better Vegas lines from DraftKings/FanDuel)
# Free tier: 500 requests/month — https://the-odds-api.com
ODDS_API_KEY=

# Cache settings
CACHE_TTL_HOURS=4
CACHE_DIR=./cache

# Database path
DB_PATH=./data/epl_oracle.db

# Logging
LOG_LEVEL=info
LOG_FORMAT=pretty
NODE_ENV=development
